{
  "name": "claude-feishu-channel",
  "version": "0.3.3",
  "description": "Bridge a Claude Code session to a Feishu bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blackman99/claude-feishu-channel"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cfc": "dist/cli.js"
  },
  "files": [
    "dist",
    "config.example.toml"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "node --import tsx src/cli.ts",
    "prepublishOnly": "npm run build && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev site",
    "docs:build": "vitepress build site",
    "docs:preview": "vitepress preview site"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  }
}
